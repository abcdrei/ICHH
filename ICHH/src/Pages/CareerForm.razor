							<li><a class="twitter" href="https://x.com/IntuitiveCare_" target="_blank"><i class="fa-brands fa-twitter"></i></a></li>
						</ul>
					</div>
				</div>
				<div class="col-xl-3 col-lg-6 col-md-6 col-12 mb-0 md-mb-6 lg-mb-5 fs-14 lh-24">
					<span class="fs-16 lh-16 mb-3 fw-600 text-uppercase d-block text-white mb-5px">Home Health Services</span>
					<ul class="text-white m-0 p-0">
						<li><a class="text-white opacity-50" href="/skilled-nurse">Skilled Nurse</a></li>
